@model ClinicaEscolaBase.Models.Atendimento

@{
    ViewData["Title"] = "Detalhes do Atendimento";
}

<h1>Detalhes do Atendimento</h1>

<div class="card shadow-sm mb-4">
    <div class="card-body">
        <dl class="row mb-0">
            <dt class="col-sm-3">Paciente</dt>
            <dd class="col-sm-9">@Model.Paciente?.NomeCompleto</dd>

            <dt class="col-sm-3">Prontuário</dt>
            <dd class="col-sm-9">@Model.Prontuario?.NumeroProntuario</dd>

            <dt class="col-sm-3">Tipo de Atendimento</dt>
            <dd class="col-sm-9">@Model.TipoAtendimento</dd>

            <dt class="col-sm-3">Status</dt>
            <dd class="col-sm-9">@Model.StatusAtendimento</dd>

            <dt class="col-sm-3">Data / Hora Início</dt>
            <dd class="col-sm-9">@Model.DataHoraInicio.ToString("dd/MM/yyyy HH:mm")</dd>

            <dt class="col-sm-3">Data / Hora Fim</dt>
            <dd class="col-sm-9">@Model.DataHoraFim?.ToString("dd/MM/yyyy HH:mm") ?? "Não registrado"</dd>

            <dt class="col-sm-3">Falta Justificada</dt>
            <dd class="col-sm-9">@(Model.FaltaJustificada ? "Sim" : "Não")</dd>

            <dt class="col-sm-3">Observações</dt>
            <dd class="col-sm-9">@(string.IsNullOrWhiteSpace(Model.Observacoes) ? "Nenhuma observação" : Model.Observacoes)</dd>
        </dl>
    </div>
</div>

<div class="d-flex gap-2">
    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">Editar Atendimento</a>
    <a asp-action="Index" class="btn btn-secondary">Voltar para Lista</a>
    <a asp-controller="Paciente" asp-action="Details" asp-route-id="@Model.PacienteId" class="btn btn-outline-primary">Voltar ao Paciente</a>
</div>

